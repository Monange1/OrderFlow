{
  "name": "order",
  "version": "1.0.0",
  "description": "Restaurant ordering system with waiter, kitchen, cashier, and admin workflows.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "stop:ports": "powershell -ExecutionPolicy Bypass -File scripts/stop-ports.ps1",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:web": "vite --host 0.0.0.0 --port 3000 --strictPort apps/web",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p apps/api/tsconfig.json",
    "build:web": "vite build apps/web",
    "start:api": "node dist/api/server.js",
    "db:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "db:seed": "tsx apps/api/prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
